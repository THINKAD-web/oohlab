# ────────────────────────────────────────────────────────────
#  OOH-LAB 환경변수 템플릿
#  실제 배포 시 .env.local (개발) 또는 Vercel 대시보드에 설정
# ────────────────────────────────────────────────────────────

# 사이트 공식 URL (SEO, sitemap, canonical 등에 사용)
NEXT_PUBLIC_SITE_URL=https://oohlab.co.kr

# ── 문의 폼 (Resend API) ────────────────────────────
# https://resend.com 가입 → API Keys → 새 키 생성
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# 발신자 주소 (Resend에서 도메인 검증 필요)
CONTACT_FROM_EMAIL="OOH-LAB <noreply@oohlab.co.kr>"
# 수신자 주소 (담당자)
CONTACT_TO_EMAIL=contact@oohlab.co.kr

# ── 문의 폼 (Slack 알림, 선택) ─────────────────────
# Slack App → Incoming Webhooks에서 URL 발급
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX

# ── 카카오 채널 링크 ────────────────────────────────
NEXT_PUBLIC_KAKAO_CHANNEL_URL=https://pf.kakao.com/_OOHLABchannel

# ── 웹마스터 인증 (선택) ────────────────────────────
# Naver Search Advisor → 사이트 등록 후 메타태그 값
NAVER_SITE_VERIFICATION=
# Google Search Console → 소유권 확인 (HTML 태그) 값
GOOGLE_SITE_VERIFICATION=

# ── Google Analytics (선택) ─────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
